        {
          "id": "ae1e6907-9286-4dfd-9814-14852df29838",
          "name": "Get Diagram via GET",
          "request": {
            "name": "Get Diagram via GET",
            "description": {
              "content": "Generates a diagram from an encoded source using a GET request. The diagram source must be compressed with deflate and encoded in base64url format. The diagram type and output format are specified in the URL path.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ":diagram_type",
                ":output_format",
                ":encoded_diagram"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "diagram_type",
                  "description": "(Required) The type of diagram to generate. Supported types: plantuml, mermaid, graphviz, blockdiag, seqdiag, actdiag, nwdiag, packetdiag, rackdiag, bpmn, bytefield, c4plantuml, d2, dbml, ditaa, erd, excalidraw, nomnoml, pikchr, structurizr, svgbob, symbolator, tikz, umlet, vega, vega-lite, wavedrom, wireviz"
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "output_format",
                  "description": "(Required) Output format for the diagram. Supported formats: svg, png, jpeg, pdf (availability depends on diagram type)"
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "encoded_diagram",
                  "description": "(Required) Deflate + base64url encoded diagram source text"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "image/svg+xml"
              }
            ],
            "method": "GET",
            "auth": null
